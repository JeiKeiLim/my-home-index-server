# port-manager — example environment file.
# Copy to .env and edit. Values here match the defaults documented in
# .tenet/spec/2026-04-17-port-manager.md §7 (Auth Flow) and §12 (Build/Run).

# Required. Bearer token AND login-form password. If empty at startup,
# the binary generates a 32-byte random token, prints it to stdout
# exactly once, and persists it back to .env for subsequent runs.
AUTH_TOKEN=

# Required. 32+ byte secret used to HMAC-sign pm_session cookies.
# If empty, the binary auto-generates and persists a value.
# Rotating this value invalidates all existing sessions.
SESSION_SECRET=

# Public hostname the dashboard advertises in copied URLs.
# Default: yourhost.example (RFC 6761 reserved placeholder — set this
# to your own router hostname before running).
PUBLIC_HOST=yourhost.example

# TCP port the dashboard listens on (0.0.0.0:PORT).
# Default: 40000
PORT=40000

# Inclusive range of ports the scanner surfaces and actions may target.
# Format: "<min>-<max>". Pick a range matching your own router's
# port-forward rules; defaults are a neutral example.
# Default: 40000-40500
PORT_RANGE=40000-40500

# Milliseconds the kill handler waits between SIGTERM and SIGKILL
# escalation. Default: 3000
KILL_GRACE_MS=3000

# Scanner implementation. "auto" picks libproc on darwin, else lsof.
# Override with "lsof" to force the subprocess fallback.
# Default: auto
SCANNER=auto
